# Copy to .env and fill in values. Never commit .env.

# Required for `docker compose up` (local Postgres)
POSTGRES_PASSWORD=your_local_password

# Database URL — must match POSTGRES_* vars if using local Docker
DATABASE_URL=postgres://app_user:your_local_password@localhost:5433/stablecoin_local

# Dune Analytics (for admin sync)
DUNE_API_KEY=

# Admin endpoint protection
ADMIN_SECRET=
